generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FaceStatus {
  NOT_ENROLLED
  ENROLLED
}

enum PaymentMethod {
  TNG
  FACE2GO
  FALLBACK
}

enum TxStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_FALLBACK
  FAILED
}

enum VerificationStatus {
  PASSED
  FAILED
  FALLBACK_REQUIRED
}

model User {
  id                      String     @id @default(uuid())
  name                    String
  email                   String     @unique
  passwordHash            String
  passcodeHash            String
  walletBalance           Decimal    @default(0) @db.Decimal(12, 2)
  faceImageKey            String?
  faceId                  String?
  rekognitionCollectionId String?
  faceEnrollmentStatus    FaceStatus @default(NOT_ENROLLED)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  paymentsToAuthorize Transaction[]      @relation("PayerTransactions")
  paymentRequests     Transaction[]      @relation("ReceiverTransactions")
  verifications       FaceVerification[]
}

model Transaction {
  id              String         @id @default(uuid())
  payerId         String
  receiverId      String
  amount          Decimal        @db.Decimal(12, 2)
  method          PaymentMethod?
  status          TxStatus       @default(PENDING)
  confidenceScore Float?
  failureReason   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  payer             User               @relation("PayerTransactions", fields: [payerId], references: [id], onDelete: Cascade)
  receiver          User               @relation("ReceiverTransactions", fields: [receiverId], references: [id], onDelete: Cascade)
  faceVerifications FaceVerification[]

  @@index([payerId, createdAt])
  @@index([receiverId, createdAt])
  @@index([status, createdAt])
}

model FaceVerification {
  id                 String             @id @default(uuid())
  userId             String
  transactionId      String
  confidenceScore    Float
  verificationStatus VerificationStatus
  createdAt          DateTime           @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([transactionId])
}
