generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FaceStatus {
  NOT_ENROLLED
  ENROLLED
}

enum PaymentMethod {
  TNG
  FACE2GO
  FALLBACK
}

enum TxStatus {
  PENDING
  SUCCESS
  SUCCESS_WITH_FALLBACK
  FAILED
}

enum VerificationStatus {
  PASSED
  FAILED
  FALLBACK_REQUIRED
}

model User {
  id                     String     @id @default(uuid())
  name                   String
  email                  String     @unique
  passwordHash           String
  passcodeHash           String
  walletBalance          Decimal    @default(0) @db.Decimal(12, 2)
  // S3 key of the enrollment image (enrollments/{userId}/face.jpg)
  faceImageKey           String?
  // Rekognition faceId returned by IndexFaces (stored for reference)
  faceId                 String?
  // Rekognition collection the face was indexed into
  rekognitionCollectionId String?
  faceEnrollmentStatus   FaceStatus @default(NOT_ENROLLED)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  transactions  Transaction[]
  verifications FaceVerification[]
}

model Transaction {
  id              String         @id @default(uuid())
  payerId         String
  recipient       String
  amount          Decimal        @db.Decimal(12, 2)
  method          PaymentMethod?
  status          TxStatus       @default(PENDING)
  confidenceScore Float?
  failureReason   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  payer             User               @relation(fields: [payerId], references: [id], onDelete: Cascade)
  faceVerifications FaceVerification[]

  @@index([payerId, createdAt])
}

model FaceVerification {
  id                 String             @id @default(uuid())
  userId             String
  transactionId      String
  confidenceScore    Float
  verificationStatus VerificationStatus
  createdAt          DateTime           @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([transactionId])
}
