PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/face2go
JWT_SECRET=replace_with_a_long_random_secret_at_least_24_chars
FRONTEND_URL=http://localhost:3000

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket for temporary face images
# Folder structure: enrollments/{userId}/face.jpg | verifications/{txId}/face.jpg
S3_BUCKET=facepay-bucket-186099270139

# Rekognition Collection ID (must be created in AWS console or via CLI)
# aws rekognition create-collection --collection-id facepay-users --region ap-southeast-1
REKOGNITION_COLLECTION_ID=facepay-users

# Confidence threshold for face match (0-100). Recommended: 95 for fintech demo.
REKOGNITION_THRESHOLD=95

# ── DynamoDB ──────────────────────────────────────────────────────────────────
# Table for user-face mapping (written by Lambda 1 after IndexFaces)
# Partition key: userId (String)
DYNAMO_FACE_TABLE=FacePayUsers

# Table for verification results (written by Lambda 2 after SearchFacesByImage)
# Partition key: verificationId (String)
# GSI: transactionId-index on transactionId (String)
DYNAMO_VERIF_TABLE=FacePayVerifications

# ── Lambda polling ────────────────────────────────────────────────────────────
# How often to check DynamoDB for Lambda result (ms)
POLL_INTERVAL_MS=1500
# Max time to wait before giving up (ms)
POLL_TIMEOUT_MS=20000

# ── Misc ──────────────────────────────────────────────────────────────────────
AUTO_SEED=false

# Optional local seed user; leave empty to avoid hardcoded data
SEED_USER_EMAIL=
SEED_USER_NAME=
SEED_USER_PASSWORD=
SEED_USER_PASSCODE=
SEED_USER_BALANCE=
